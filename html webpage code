<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jal Pariksha – Water Quality Monitor</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;800&family=Tiro+Devanagari+Hindi&display=swap" rel="stylesheet">
<style>
  :root {
    --sky: #e8f4f8;
    --earth: #5c3d1e;
    --mud: #8b5e3c;
    --leaf: #3a7d44;
    --leaf-light: #5daa6a;
    --straw: #f2c94c;
    --salt: #b2d8e8;
    --fresh: #4caf8a;
    --brackish: #8bc34a;
    --warm: #e07b39;
    --cool: #5b9bd5;
    --card-bg: #fffdf7;
    --border: #d4a96a;
    --shadow: rgba(92,61,30,0.12);
    --text: #3b2a1a;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Baloo 2', cursive;
    background: var(--sky);
    min-height: 100vh;
    color: var(--text);
    overflow-x: hidden;
  }

  /* Animated background */
  body::before {
    content:'';
    position:fixed; inset:0;
    background:
      radial-gradient(ellipse 80% 40% at 50% 100%, #c8e6c9 0%, transparent 60%),
      radial-gradient(ellipse 60% 30% at 80% 80%, #b3e0f7 0%, transparent 50%),
      linear-gradient(180deg, #ddeeff 0%, #e8f4f8 40%, #f0ede0 100%);
    z-index:-1;
  }

  /* Sun */
  .sun {
    position:fixed; top:24px; right:32px;
    width:72px; height:72px;
    background: radial-gradient(circle, #ffe066 60%, #ffb300 100%);
    border-radius:50%;
    box-shadow: 0 0 0 10px rgba(255,224,102,0.2), 0 0 0 24px rgba(255,224,102,0.08);
    animation: sunpulse 3s ease-in-out infinite;
    z-index:0;
  }
  @keyframes sunpulse {
    0%,100% { box-shadow: 0 0 0 10px rgba(255,224,102,0.2), 0 0 0 24px rgba(255,224,102,0.08); }
    50% { box-shadow: 0 0 0 16px rgba(255,224,102,0.25), 0 0 0 36px rgba(255,224,102,0.10); }
  }

  /* Header */
  header {
    text-align:center;
    padding: 36px 20px 10px;
    position:relative;
  }
  .header-icon {
    font-size: 3.5rem;
    display:block;
    animation: bob 2.5s ease-in-out infinite;
  }
  @keyframes bob {
    0%,100%{ transform:translateY(0); }
    50%{ transform:translateY(-8px); }
  }
  h1 {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 800;
    color: var(--earth);
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  .subtitle {
    font-size: 1.05rem;
    color: var(--mud);
    margin-top: 4px;
    font-weight: 400;
  }
  .subtitle-ta {
    font-size:0.95rem;
    color: #a07040;
    margin-top:2px;
  }

  /* Serial connection bar */
  .connect-bar {
    display:flex; align-items:center; justify-content:center; gap:12px;
    background: var(--card-bg);
    border: 2px solid var(--border);
    border-radius: 18px;
    padding: 14px 24px;
    margin: 22px auto 0;
    max-width: 560px;
    box-shadow: 0 4px 20px var(--shadow);
    flex-wrap: wrap;
  }
  .connect-bar select {
    font-family: 'Baloo 2', cursive;
    font-size: 1rem;
    padding: 8px 14px;
    border-radius: 12px;
    border: 2px solid var(--border);
    background: #fdf8ef;
    color: var(--text);
    cursor:pointer;
    outline:none;
    flex:1; min-width:140px;
  }
  .btn {
    font-family: 'Baloo 2', cursive;
    font-size: 1rem;
    font-weight: 700;
    padding: 9px 22px;
    border-radius: 14px;
    border: none;
    cursor:pointer;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .btn:active { transform:scale(0.96); }
  .btn-connect {
    background: var(--leaf);
    color:#fff;
    box-shadow: 0 3px 12px rgba(58,125,68,0.3);
  }
  .btn-connect:hover { background: var(--leaf-light); box-shadow: 0 5px 18px rgba(58,125,68,0.4); }
  .btn-connect.connected { background: #c0392b; box-shadow: 0 3px 12px rgba(192,57,43,0.3); }
  .btn-manual {
    background: var(--straw);
    color: var(--earth);
    box-shadow: 0 3px 10px rgba(242,201,76,0.3);
    font-size:0.9rem;
    padding:8px 16px;
  }
  .btn-manual:hover { filter:brightness(1.05); }

  .status-dot {
    width:13px; height:13px;
    border-radius:50%;
    background: #ccc;
    flex-shrink:0;
    transition: background 0.3s;
  }
  .status-dot.connected { background: var(--leaf); box-shadow:0 0 0 4px rgba(58,125,68,0.2); animation: blink 1.5s infinite; }
  .status-dot.disconnected { background: #e74c3c; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .status-text { font-size:0.9rem; color:var(--mud); font-weight:600; }

  /* Main grid */
  .main-grid {
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 22px;
    max-width: 900px;
    margin: 28px auto 0;
    padding: 0 18px;
  }

  /* Cards */
  .card {
    background: var(--card-bg);
    border: 2.5px solid var(--border);
    border-radius: 28px;
    padding: 28px 24px;
    box-shadow: 0 6px 30px var(--shadow);
    position:relative;
    overflow:hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .card:hover { transform:translateY(-3px); box-shadow:0 12px 40px rgba(92,61,30,0.16); }

  .card-label {
    font-size:0.85rem;
    font-weight:700;
    letter-spacing:1.5px;
    text-transform:uppercase;
    color: var(--mud);
    margin-bottom: 12px;
    display:flex; align-items:center; gap:8px;
  }

  /* Water Type Card */
  .water-display {
    text-align:center;
    padding: 12px 0 6px;
  }
  .water-icon-big {
    font-size: 5rem;
    display:block;
    line-height:1;
    animation: wiggle 3s ease-in-out infinite;
  }
  @keyframes wiggle {
    0%,100%{ transform:rotate(-3deg); }
    50%{ transform:rotate(3deg); }
  }
  .water-type-name {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    margin-top: 10px;
    transition: color 0.5s;
  }
  .water-type-desc {
    font-size: 0.95rem;
    color: var(--mud);
    margin-top: 6px;
    line-height: 1.5;
  }
  .water-badge {
    display:inline-block;
    padding: 5px 18px;
    border-radius: 999px;
    font-size:0.88rem;
    font-weight:700;
    margin-top:12px;
    transition: all 0.5s;
  }

  /* Color themes per water type */
  .type-fresh .water-type-name { color: var(--fresh); }
  .type-fresh .water-badge { background: #e8f8f1; color: var(--fresh); border:2px solid var(--fresh); }
  .type-salty .water-type-name { color: #2980b9; }
  .type-salty .water-badge { background: #eaf4fb; color: #2980b9; border:2px solid #2980b9; }
  .type-brackish .water-type-name { color: #7d6608; }
  .type-brackish .water-badge { background: #fefde7; color: #7d6608; border:2px solid #c9b000; }
  .type-unknown .water-type-name { color: #aaa; }
  .type-unknown .water-badge { background: #f5f5f5; color:#999; border:2px solid #ddd; }

  /* Wave strip */
  .wave-strip {
    height:8px; border-radius:4px;
    background: linear-gradient(90deg, #b3e0f7, #4caf8a, #b3e0f7);
    background-size:200% 100%;
    animation: wavemove 3s linear infinite;
    margin-top:16px;
    opacity:0.6;
  }
  @keyframes wavemove { 0%{background-position:0%} 100%{background-position:200%} }

  /* Temperature Card */
  .temp-display {
    text-align:center;
  }
  .thermometer {
    position:relative;
    width:56px; height:160px;
    margin:0 auto 12px;
  }
  .therm-tube {
    position:absolute; left:50%; transform:translateX(-50%);
    width:24px; height:130px; bottom:30px;
    background:#f0ede0;
    border:3px solid var(--border);
    border-radius:12px 12px 0 0;
    overflow:hidden;
  }
  .therm-fill {
    position:absolute; bottom:0; left:0; right:0;
    background: linear-gradient(180deg, #ff6b35, #e74c3c);
    transition: height 1s cubic-bezier(.4,0,.2,1);
    border-radius:8px 8px 0 0;
  }
  .therm-bulb {
    position:absolute; bottom:0; left:50%; transform:translateX(-50%);
    width:36px; height:36px;
    border-radius:50%;
    background: radial-gradient(circle at 40% 40%, #ff8c69, #e74c3c);
    border:3px solid var(--border);
    z-index:2;
  }
  .temp-ticks {
    position:absolute; right:-18px; top:4px;
    height:130px;
    display:flex; flex-direction:column; justify-content:space-between;
    font-size:0.65rem; color:var(--mud);
  }

  .temp-value {
    font-size: clamp(2.2rem, 6vw, 3rem);
    font-weight:800;
    letter-spacing:-1px;
    transition: color 0.5s;
  }
  .temp-feels {
    font-size:0.92rem;
    color:var(--mud);
    margin-top:4px;
  }
  .temp-advice {
    font-size:0.88rem;
    background:#fdf8ef;
    border:1.5px solid var(--border);
    border-radius:12px;
    padding: 8px 14px;
    margin-top:14px;
    color:var(--earth);
    line-height:1.5;
  }

  /* Farm advice card */
  .advice-card {
    background: linear-gradient(135deg, #e8f5e9, #fffdf7);
    border-color: var(--leaf-light);
  }
  .advice-list { list-style:none; margin-top:10px; }
  .advice-list li {
    display:flex; align-items:flex-start; gap:10px;
    padding:9px 0;
    border-bottom:1.5px dashed #d0e8d0;
    font-size:0.95rem;
    color:var(--text);
    line-height:1.5;
  }
  .advice-list li:last-child { border-bottom:none; }
  .advice-emoji { font-size:1.3rem; flex-shrink:0; margin-top:1px; }

  /* Raw data log */
  .log-card { background: #1a1208; border-color:#5c3d1e; }
  .log-label { color: #a07040 !important; }
  .log-box {
    font-family: 'Courier New', monospace;
    font-size:0.82rem;
    color:#7ec8a0;
    height:110px;
    overflow-y:auto;
    background:#120d04;
    border-radius:10px;
    padding:10px 12px;
    margin-top:8px;
    line-height:1.8;
  }
  .log-box::-webkit-scrollbar { width:4px; }
  .log-box::-webkit-scrollbar-thumb { background:#5c3d1e; border-radius:4px; }
  .log-line { animation:fadeIn 0.4s ease; }
  @keyframes fadeIn{ from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }
  .log-time { color:#5b8a6a; margin-right:6px; }

  /* Manual input panel */
  .manual-panel {
    background: var(--card-bg);
    border: 2px dashed var(--border);
    border-radius: 22px;
    padding:22px 24px;
    max-width:900px;
    margin:18px auto 0;
    padding-left:18px; padding-right:18px;
    display:none;
  }
  .manual-panel.visible { display:block; }
  .manual-panel h3 { font-size:1.1rem; color:var(--earth); margin-bottom:14px; }
  .manual-row { display:flex; flex-wrap:wrap; gap:14px; align-items:center; }
  .manual-row select, .manual-row input {
    font-family:'Baloo 2', cursive;
    font-size:1rem;
    padding:9px 16px;
    border-radius:14px;
    border:2px solid var(--border);
    background:#fdf8ef;
    color:var(--text);
    outline:none;
    flex:1; min-width:140px;
  }
  .btn-apply {
    background: var(--earth);
    color:#fff;
    box-shadow:0 3px 12px rgba(92,61,30,0.3);
  }
  .btn-apply:hover { background:var(--mud); }

  /* Footer */
  footer {
    text-align:center;
    padding:30px 16px 40px;
    color: #a07040;
    font-size:0.88rem;
  }
  footer span { display:block; margin-top:4px; }

  /* Last updated pill */
  .last-update {
    display:inline-block;
    font-size:0.8rem;
    background:#f0ede0;
    border:1.5px solid var(--border);
    border-radius:999px;
    padding:3px 14px;
    color:var(--mud);
    margin-top:14px;
  }

  /* Responsive */
  @media(max-width:500px){
    .connect-bar { padding:12px 14px; }
    .card { padding:20px 16px; }
  }
</style>
</head>
<body>

<div class="sun"></div>

<header>
  <span class="header-icon">🌾</span>
  <h1>Jal Pariksha</h1>
  <div class="subtitle">Water Quality Monitor for Farmers</div>
  <div class="subtitle-ta">पानी की जांच – किसान मित्र</div>
</header>

<!-- Serial Connection Bar -->
<div style="max-width:860px;margin:0 auto;padding:0 18px;">
  <div class="connect-bar">
    <div class="status-dot disconnected" id="statusDot"></div>
    <span class="status-text" id="statusText">Not Connected</span>
    <select id="baudRate">
      <option value="9600" selected>9600 baud</option>
      <option value="115200">115200 baud</option>
      <option value="57600">57600 baud</option>
    </select>
    <button class="btn btn-connect" id="connectBtn" onclick="toggleSerial()">🔌 Connect Arduino</button>
    <button class="btn btn-manual" onclick="toggleManual()">✏️ Enter Manually</button>
  </div>

  <!-- Manual input panel -->
  <div class="manual-panel" id="manualPanel">
    <h3>📝 Enter Reading Manually (for testing)</h3>
    <div class="manual-row">
      <select id="manualType">
        <option value="freshwater">🟢 Fresh Water</option>
        <option value="saltwater">🔵 Salty Water</option>
        <option value="brackish">🟡 Brackish Water</option>
      </select>
      <input type="number" id="manualTemp" placeholder="Temperature °C" min="0" max="100" value="28">
      <button class="btn btn-apply btn-manual" onclick="applyManual()">✅ Apply</button>
    </div>
  </div>
</div>

<!-- Main Grid -->
<div class="main-grid">

  <!-- Water Type Card -->
  <div class="card type-unknown" id="waterCard">
    <div class="card-label">💧 Water Type</div>
    <div class="water-display">
      <span class="water-icon-big" id="waterIcon">❓</span>
      <div class="water-type-name" id="waterName">Waiting…</div>
      <div class="water-type-desc" id="waterDesc">Connect Arduino or enter data manually to see results.</div>
      <span class="water-badge" id="waterBadge">-- ppm</span>
    </div>
    <div class="wave-strip"></div>
    <div class="last-update" id="waterTime">Last update: --</div>
  </div>

  <!-- Temperature Card -->
  <div class="card">
    <div class="card-label">🌡️ Water Temperature</div>
    <div class="temp-display">
      <div class="thermometer">
        <div class="therm-tube">
          <div class="therm-fill" id="thermFill" style="height:30%"></div>
        </div>
        <div class="therm-bulb"></div>
        <div class="temp-ticks">
          <span>50°</span>
          <span>40°</span>
          <span>30°</span>
          <span>20°</span>
          <span>10°</span>
        </div>
      </div>
      <div class="temp-value" id="tempValue">-- °C</div>
      <div class="temp-feels" id="tempFeels">Waiting for sensor…</div>
      <div class="temp-advice" id="tempAdvice">📡 Connect your Arduino sensor to read temperature.</div>
    </div>
  </div>

  <!-- Farming Advice Card -->
  <div class="card advice-card" id="adviceCard">
    <div class="card-label">🌱 Farming Advice</div>
    <ul class="advice-list" id="adviceList">
      <li><span class="advice-emoji">📡</span><span>Connect your Arduino to get personalised farming advice based on your water quality.</span></li>
    </ul>
  </div>

  <!-- Raw Data Log -->
  <div class="card log-card">
    <div class="card-label log-label">📟 Arduino Serial Log</div>
    <div class="log-box" id="logBox">
      <div class="log-line"><span class="log-time">[--:--:--]</span> Waiting for Arduino data...</div>
    </div>
  </div>

</div>

<footer>
  Made with ❤️ for Indian Farmers
  <span>Arduino → Web Serial API → Jal Pariksha</span>
  <span style="font-size:0.78rem;margin-top:4px;">Use Chrome/Edge browser for Web Serial API support</span>
</footer>

<script>
/* ===== STATE ===== */
let port = null, reader = null;
let connected = false;
let buffer = '';
let manualVisible = false;

/* ===== SERIAL CONNECTION ===== */
async function toggleSerial() {
  if (connected) {
    await disconnectSerial();
  } else {
    await connectSerial();
  }
}

async function connectSerial() {
  if (!('serial' in navigator)) {
    alert('⚠️ Web Serial API not supported!\n\nPlease use Google Chrome or Microsoft Edge browser.\n\nAlternatively, use the "Enter Manually" button to test the app.');
    return;
  }
  try {
    port = await navigator.serial.requestPort();
    const baud = parseInt(document.getElementById('baudRate').value);
    await port.open({ baudRate: baud });

    connected = true;
    updateStatus(true);
    addLog('✅ Arduino connected at ' + baud + ' baud');
    readSerial();
  } catch(e) {
    if (e.name !== 'NotFoundError') {
      addLog('❌ Error: ' + e.message);
    }
  }
}

async function disconnectSerial() {
  try {
    if (reader) { await reader.cancel(); reader = null; }
    if (port) { await port.close(); port = null; }
  } catch(e) {}
  connected = false;
  updateStatus(false);
  addLog('🔌 Arduino disconnected');
}

async function readSerial() {
  const decoder = new TextDecoderStream();
  port.readable.pipeTo(decoder.writable);
  reader = decoder.readable.getReader();
  try {
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      buffer += value;
      let lines = buffer.split('\n');
      buffer = lines.pop();
      lines.forEach(line => {
        line = line.trim();
        if (line) {
          addLog('📩 ' + line);
          parseLine(line);
        }
      });
    }
  } catch(e) {
    if (connected) {
      addLog('⚠️ Connection lost: ' + e.message);
      disconnectSerial();
    }
  }
}

/* ===== PARSE ARDUINO DATA ===== */
/*
  Expected Arduino format (one of):
    TYPE:freshwater,TEMP:28.5
    TYPE:saltwater,TEMP:32.1
    TYPE:brackish,TEMP:25.0
  OR just:
    freshwater,28.5
    WATER:freshwater
    TEMP:28.5
*/
function parseLine(line) {
  line = line.toLowerCase();
  let waterType = null, temp = null;

  // Match TYPE:xxx
  const typeMatch = line.match(/type[:\s]+(\w+)/);
  if (typeMatch) waterType = typeMatch[1];

  // Match TEMP:xx.x or TEMPERATURE:xx.x
  const tempMatch = line.match(/temp[eratur]*[:\s]+([\d.]+)/);
  if (tempMatch) temp = parseFloat(tempMatch[1]);

  // Fallback: detect water type keywords anywhere
  if (!waterType) {
    if (line.includes('fresh')) waterType = 'freshwater';
    else if (line.includes('salt')) waterType = 'saltwater';
    else if (line.includes('brack')) waterType = 'brackish';
  }

  // Fallback: first number in line as temp if no temp found
  if (temp === null) {
    const nums = line.match(/[\d.]+/g);
    if (nums) temp = parseFloat(nums[nums.length - 1]);
  }

  if (waterType) setWaterType(waterType);
  if (temp !== null && !isNaN(temp)) setTemperature(temp);
}

/* ===== UI UPDATES ===== */
const WATER_INFO = {
  freshwater: {
    icon: '🏞️',
    name: 'Fresh Water',
    desc: 'Clean, low-salt water — good for drinking and most crops.',
    badge: '< 500 ppm TDS',
    cls: 'type-fresh',
    advice: [
      ['🌾', 'Excellent for rice, wheat, sugarcane, and vegetables.'],
      ['🐟', 'Safe for fish farming (aquaculture).'],
      ['🚿', 'Suitable for drip and sprinkler irrigation.'],
      ['✅', 'No treatment needed. Use directly.'],
      ['💧', 'Store in clean tanks to prevent contamination.'],
    ]
  },
  saltwater: {
    icon: '🌊',
    name: 'Salty Water',
    desc: 'High salt content — not suitable for most crops directly.',
    badge: '> 3500 ppm TDS',
    cls: 'type-salty',
    advice: [
      ['🚫', 'Do NOT use directly on crops — will damage roots.'],
      ['🌴', 'Only salt-tolerant plants like mangrove or certain palms can survive.'],
      ['🐠', 'Can be used for marine fish/prawn farming in ponds.'],
      ['⚗️', 'Needs desalination or dilution before irrigation.'],
      ['📞', 'Contact your local agriculture office for treatment options.'],
    ]
  },
  brackish: {
    icon: '🏖️',
    name: 'Brackish Water',
    desc: 'Mix of fresh and salty water — use with care.',
    badge: '500–3500 ppm TDS',
    cls: 'type-brackish',
    advice: [
      ['⚠️', 'Use carefully — some crops can tolerate mild saltiness.'],
      ['🌿', 'Barley, cotton, and some vegetables can handle brackish water.'],
      ['🦐', 'Good for prawn and shrimp aquaculture.'],
      ['🔀', 'Mix with fresh water to dilute before using on fields.'],
      ['🧪', 'Test soil salinity regularly if using brackish water.'],
    ]
  }
};

function setWaterType(type) {
  const card = document.getElementById('waterCard');
  const info = WATER_INFO[type] || null;
  if (!info) return;

  card.className = 'card ' + info.cls;
  document.getElementById('waterIcon').textContent = info.icon;
  document.getElementById('waterName').textContent = info.name;
  document.getElementById('waterDesc').textContent = info.desc;
  document.getElementById('waterBadge').textContent = info.badge;
  document.getElementById('waterTime').textContent = 'Last update: ' + now();

  // Farming advice
  const list = document.getElementById('adviceList');
  list.innerHTML = info.advice.map(([e,t]) =>
    `<li><span class="advice-emoji">${e}</span><span>${t}</span></li>`
  ).join('');
}

function setTemperature(temp) {
  const pct = Math.min(100, Math.max(0, ((temp - 0) / 50) * 100));
  document.getElementById('thermFill').style.height = pct + '%';

  const el = document.getElementById('tempValue');
  el.textContent = temp.toFixed(1) + ' °C';

  // Color based on temp
  if (temp < 15) { el.style.color = '#5b9bd5'; }
  else if (temp < 28) { el.style.color = var_css('--fresh'); }
  else if (temp < 35) { el.style.color = '#e07b39'; }
  else { el.style.color = '#e74c3c'; }

  let feels = '', advice = '';
  if (temp < 10) {
    feels = '🧊 Very Cold'; advice = '❄️ Water is very cold. Fish and plants may become sluggish. Avoid irrigation in early morning.';
  } else if (temp < 20) {
    feels = '😌 Cool'; advice = '✅ Cool water. Good for cool-season vegetables like spinach, peas. Fish are comfortable.';
  } else if (temp < 28) {
    feels = '😊 Pleasant – Ideal'; advice = '🌟 Ideal temperature! Perfect for most crops and fish farming. Best time to irrigate.';
  } else if (temp < 35) {
    feels = '☀️ Warm'; advice = '⚠️ Warm water. Irrigate early morning or evening to reduce evaporation. Monitor fish closely.';
  } else {
    feels = '🔥 Too Hot!'; advice = '🆘 Water too hot! Avoid direct irrigation. Can stress plant roots and harm fish. Let it cool first.';
  }

  document.getElementById('tempFeels').textContent = feels;
  document.getElementById('tempAdvice').textContent = advice;
}

function var_css(name) {
  return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
}

/* ===== LOG ===== */
function addLog(msg) {
  const box = document.getElementById('logBox');
  const div = document.createElement('div');
  div.className = 'log-line';
  div.innerHTML = `<span class="log-time">[${now()}]</span> ${msg}`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  if (box.children.length > 60) box.removeChild(box.firstChild);
}

function now() {
  return new Date().toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
}

/* ===== STATUS ===== */
function updateStatus(on) {
  const dot = document.getElementById('statusDot');
  const txt = document.getElementById('statusText');
  const btn = document.getElementById('connectBtn');
  dot.className = 'status-dot ' + (on ? 'connected' : 'disconnected');
  txt.textContent = on ? '🟢 Arduino Connected' : '🔴 Not Connected';
  btn.textContent = on ? '⏏️ Disconnect' : '🔌 Connect Arduino';
  btn.className = 'btn btn-connect' + (on ? ' connected' : '');
}

/* ===== MANUAL INPUT ===== */
function toggleManual() {
  manualVisible = !manualVisible;
  document.getElementById('manualPanel').className = 'manual-panel' + (manualVisible ? ' visible' : '');
}

function applyManual() {
  const type = document.getElementById('manualType').value;
  const temp = parseFloat(document.getElementById('manualTemp').value);
  setWaterType(type);
  if (!isNaN(temp)) setTemperature(temp);
  addLog('✏️ Manual entry — Type: ' + type + ', Temp: ' + temp + '°C');
}

